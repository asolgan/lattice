# Compose .env for the hosted demo box: bind every published container port to
# loopback so the only network-reachable surface is the reverse proxy in front
# of Facet. docker-compose.yml's port entries are "${VAR:-port}:port", so a
# host-IP value here renders e.g. "127.0.0.1:4222:4222". Copy to the repo root
# as `.env` (demo-bootstrap.sh does this). Docker port publishing bypasses
# host firewalls like ufw — these loopback binds are the host-side wall; pair
# them with the provider's network firewall (inbound 22/80/443 only).
NATS_PORT=127.0.0.1:4222
NATS_WS_PORT=127.0.0.1:9222
NATS_HTTP_PORT=127.0.0.1:8222
POSTGRES_PORT=127.0.0.1:5432
